---
import { getCollection } from 'astro:content'
import PageLayout from '@/layouts/CommonPage.astro'

const allPosts = await getCollection('blog')
const posts = allPosts
  .filter(post => post.data.tags?.includes('study'))
  .sort((a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf())

const headings = [{ depth: 2, slug: 'study', text: 'Study' }]
---

<PageLayout title='Study' {headings}>
  <h2 id='study'>Study</h2>
  <p class="mb-6 text-gray-400">Page 1 - Showing {posts.length} of {posts.length} posts</p>
  
  <div class="grid gap-6">
    {posts.map(post => (
      <article class="border border-gray-700 rounded-lg p-5 hover:bg-gray-800 transition">
        <h3 class="text-xl font-bold">
          <a href={`/blog/${post.id}`}>{post.data.title}</a>
        </h3>
        <p class="text-gray-400 mt-2">{post.data.description}</p>
        <div class="flex gap-3 mt-3 text-sm text-gray-500">
          <time>{post.data.publishDate}</time>
          <span>•</span>
          <span>{post.data.tags?.join(', ')}</span>
        </div>
      </article>
    ))}
  </div>
  
  {posts.length === 0 && (
    <p class="text-gray-500 mt-8">该分类下暂无文章。</p>
  )}
</PageLayout>