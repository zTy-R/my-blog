---
import { Image } from 'astro:assets'

import { Button, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'

const headings = [
  { depth: 2, slug: 'programs', text: 'Programs' },
  { depth: 2, slug: 'learnings', text: 'Learnings' }
]
---

<PageLayout title='Projects' {headings}>
  <p>我的 GitHub 活跃情况：</p>
  <p>
    <Image
      src='https://ghchart.rshah.org/659eb9/zTy-R'
      alt='github activities'
      inferSize
      loading='lazy'
    />
  </p>
  <p>
    如果你对我的项目感兴趣，欢迎通过 GitHub 与我交流或提交 PR。
  </p>
  <Button title='My GitHub' class='w-fit' href='https://github.com/zTy-R' target='_blank'>
    <Icon class='size-5' name='github' slot='before' />
  </Button>

  <h2 id='programs'>Programs</h2>
  <p class='text-muted-foreground'>暂无公开项目，正在学习和积累中……</p>

  <h2 id='learnings'>Learnings</h2>
  <p class='text-muted-foreground'>学习笔记和练习项目会陆续整理在这里。</p>
</PageLayout>
